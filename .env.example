# Optional: Telegram API credentials (get them from https://my.telegram.org)
# These can be configured from the web UI instead (Settings -> Telegram),
# where they are stored encrypted in the database. Values saved in the web UI
# take precedence over these; .env is only a fallback.
# API_ID=your_api_id_here
# API_HASH=your_api_hash_here

# Optional: chat ID to seed the monitored channel list (negative number for
# groups/channels). Channels are managed from the web UI (Settings -> Telegram)
# and stored in the database; this value is only used on first run.
# To get chat ID: forward a message from the chat to @userinfobot
# CHAT_ID=your_chat_id_here

# Download Directory
# Telegram files go to DOWNLOAD_DIR/Telegram, URL downloads go to DOWNLOAD_DIR/Videos
DOWNLOAD_DIR=/path/to/downloads

# Web Interface Configuration
WEB_PORT=4444
WEB_HOST=0.0.0.0

# Download Configuration
MAX_RETRIES=6

# PostgreSQL Database Configuration
# Create a dedicated user: CREATE USER telegram_user WITH PASSWORD 'your_password';
# Create database: CREATE DATABASE telegram_downloader OWNER telegram_user;
DATABASE_URL=postgresql://telegram_user:your_password@localhost:5432/telegram_downloader

# Application secret - signs login tokens (JWT) and encrypts secrets stored
# in the database (VPS/torrent passwords, Telegram API hash).
# Recommended: set it explicitly, e.g. with
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# If unset, a random secret is generated on first start and persisted to
# .jwt_secret (mode 0600) next to this file, then reused on later startups.
# Changing the secret logs everyone out (existing JWTs become invalid).
# JWT_SECRET=your_secret_key_here
